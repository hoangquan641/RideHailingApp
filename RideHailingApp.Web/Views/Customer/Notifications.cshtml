@model List<RideHailingApp.DAL.Entities.Ride>
@{
    ViewData["Title"] = "Thông báo";
}

<div class="container-fluid mt-4 px-3 mb-5 pb-5">
    <h4 class="fw-bold text-dark mb-4">Thông báo của bạn</h4>

    <h6 class="fw-bold text-secondary mb-3 mt-4" style="font-size: 0.85rem;">CẬP NHẬT HÀNH TRÌNH</h6>

    @if (Model != null && Model.Any())
    {
        foreach (var ride in Model)
        {
            // Thiết lập mặc định
            string iconClass = "bi-car-front-fill text-primary";
            string bgClass = "bg-primary bg-opacity-10";
            string title = "Đang xử lý chuyến đi";
            string message = $"Chuyến đi đến {ride.DropoffAddress} đang được hệ thống ghi nhận.";
            string timeStr = ride.CreatedAt.ToString("dd/MM/yyyy HH:mm");

            // Phân loại nội dung theo trạng thái
            if (ride.Status == RideHailingApp.Common.Enums.RideStatusEnum.Completed)
            {
                iconClass = "bi-check-circle-fill text-success";
                bgClass = "bg-success bg-opacity-10";
                title = "Chuyến đi hoàn thành";
                message = $"Bạn đã đến {ride.DropoffAddress}. Cước phí: {ride.Fare.ToString("N0")}đ.";
                timeStr = ride.CompletedAt?.ToString("dd/MM/yyyy HH:mm") ?? timeStr;
            }
            else if (ride.Status == RideHailingApp.Common.Enums.RideStatusEnum.Cancelled)
            {
                iconClass = "bi-x-circle-fill text-danger";
                bgClass = "bg-danger bg-opacity-10";
                title = "Chuyến đi đã bị hủy";
                message = $"Chuyến đi đến {ride.DropoffAddress} đã bị hủy. Lý do: {ride.CancelReason ?? "Không xác định"}.";
            }
            else if (ride.Status == RideHailingApp.Common.Enums.RideStatusEnum.Accepted || ride.Status == RideHailingApp.Common.Enums.RideStatusEnum.InProgress)
            {
                iconClass = "bi-geo-alt-fill text-info";
                bgClass = "bg-info bg-opacity-10";
                title = "Tài xế đang đến!";
                message = $"Tài xế {ride.Driver?.FullName} đang trên đường. Vui lòng di chuyển ra điểm đón nhé!";
            }

            // Giao diện 1 thẻ thông báo
            <div class="glass-panel p-3 mb-3 shadow-sm btn-effect" style="border-radius: 12px; transition: 0.3s; cursor: pointer;" onclick="window.location.href='/Customer/RideHistory'">
                <div class="d-flex align-items-start">
                    <div class="@bgClass p-2 rounded-circle me-3">
                        <i class="bi @iconClass fs-4"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1 text-dark">@title</h6>
                        <p class="text-muted small mb-1">@message</p>
                        <small class="text-secondary" style="font-size: 0.7rem;"><i class="bi bi-clock"></i> @timeStr</small>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center mt-5 opacity-50">
            <i class="bi bi-inbox-fill text-secondary" style="font-size: 4rem;"></i>
            <h6 class="mt-3 fw-bold">Chưa có chuyến đi nào</h6>
            <p class="small">Các cập nhật hành trình của bạn sẽ xuất hiện tại đây.</p>
        </div>
    }
</div>

<style>
    .btn-effect:hover {
        transform: translateY(-2px);
        background-color: #f8f9fa !important;
    }
</style>