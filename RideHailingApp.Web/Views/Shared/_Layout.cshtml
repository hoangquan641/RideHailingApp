<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - Ride Hailing</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <meta name="theme-color" content="#ffffff">
</head>
<body>

    @if (TempData["Success"] != null || TempData["Error"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function() {
            const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true,
            didOpen: (toast) => {
            toast.addEventListener('mouseenter', Swal.stopTimer)
            toast.addEventListener('mouseleave', Swal.resumeTimer)
            }
            });

            @if (TempData["Success"] != null)
            {
                <text>
                    Toast.fire({
                    icon: 'success',
                    title: '@Html.Raw(TempData["Success"])'
                    });
                </text>
            }

            @if (TempData["Error"] != null)
            {
                <text>
                    Toast.fire({
                    icon: 'error',
                    title: '@Html.Raw(TempData["Error"])'
                    });
                </text>
            }
            });
        </script>
    }

    <main role="main" class="container-fluid p-3 pb-5">
        @RenderBody()
    </main>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="floating-nav-container">
            <nav class="floating-nav">
                <a href="/" class="nav-btn">
                    <i class="bi bi-house-door-fill"></i>
                </a>

                <a href="#" class="nav-btn">
                    <i class="bi bi-receipt"></i>
                </a>

                <div class="nav-center-wrapper">
                    @if (User.IsInRole("Customer"))
                    {
                        <a asp-controller="Customer" asp-action="BookRide" class="nav-center-btn bg-success">
                            <i class="bi bi-car-front-fill"></i>
                        </a>
                    }
                    else if (User.IsInRole("Driver"))
                    {
                        <a asp-controller="Driver" asp-action="Index" class="nav-center-btn bg-warning">
                            <i class="bi bi-radar"></i>
                        </a>
                    }
                    else if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin" asp-action="Index" class="nav-center-btn bg-danger">
                            <i class="bi bi-pie-chart-fill"></i>
                        </a>
                    }
                </div>

                <a href="#" class="nav-btn">
                    <i class="bi bi-gear-fill"></i>
                </a>

                @if (User.IsInRole("Customer"))
                {
                    <a asp-controller="Customer" asp-action="Profile" class="nav-btn">
                        <i class="bi bi-person-circle"></i>
                    </a>
                }
                else if (User.IsInRole("Driver"))
                {
                    <a asp-controller="Driver" asp-action="Profile" class="nav-btn">
                        <i class="bi bi-person-circle"></i>
                    </a>
                }
                else if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="Profile" class="nav-btn">
                        <i class="bi bi-person-circle"></i>
                    </a>
                }
            </nav>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', () => {
            const currentPath = window.location.pathname.toLowerCase();
            const navBtns = document.querySelectorAll('.nav-btn');

            navBtns.forEach(btn => {
            const href = btn.getAttribute('href').toLowerCase();
            if (href !== '#' && (currentPath.includes(href) && href !== '/' || (currentPath === '/' && href === '/'))) {
            btn.classList.add('active');
            }
            });
            });
        </script>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Driver"))
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
            const currentPath = window.location.pathname.toLowerCase();
            const isMapPage = currentPath === '/driver' || currentPath.includes('/driver/index');
            const isOnline = localStorage.getItem('driverOnlineState') === 'true';

            if (!isMapPage && isOnline) {
            const globalConnection = new signalR.HubConnectionBuilder().withUrl("/rideHub").build();

            globalConnection.on("ReceiveRideRequest", function (rideId, customerName, customerPhone, pickup, dropoff, fare, rideDist, pLat, pLng, declinedJson) {

            // Lưu cuốc xe vào bộ nhớ đệm trước khi chuyển trang
            const pendingRide = {
            rideId, customerName, customerPhone, pickup, dropoff, fare, rideDist, pLat, pLng, declinedJson,
            timestamp: new Date().getTime()
            };
            localStorage.setItem('pendingRideRequest', JSON.stringify(pendingRide));

            if (Notification.permission === "granted") {
            const systemNotification = new Notification("🚕 CÓ CUỐC XE MỚI!", {
            body: `Khách hàng ${customerName} đang đợi. Bấm để mở trạm điều khiển!`,
            icon: 'https://cdn-icons-png.flaticon.com/512/3204/3204066.png',
            vibrate: [200, 100, 200, 100, 200],
            requireInteraction: true
            });
            systemNotification.onclick = function() {
            window.location.href = '/Driver/Index';
            };
            }

            Swal.fire({
            title: 'CÓ CUỐC XE MỚI!',
            text: `Khách hàng ${customerName} đang đợi bạn.`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#00b14f',
            cancelButtonColor: '#6c757d',
            confirmButtonText: '<i class="bi bi-radar"></i> Về trạm nhận cuốc',
            cancelButtonText: 'Bỏ qua',
            allowOutsideClick: false,
            timer: 15000,
            timerProgressBar: true
            }).then((result) => {
            if (result.isConfirmed) {
            window.location.href = '/Driver/Index';
            } else {
            // Nếu bấm bỏ qua, xóa bộ nhớ đệm để không hiện lại
            localStorage.removeItem('pendingRideRequest');
            }
            });

            const audio = new Audio('/sounds/ringtone.mp3');
            audio.play().catch(e => console.log(e));
            });

            globalConnection.start().catch(err => console.error(err));
            }
            });
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>