<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - Ride Hailing</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <meta name="theme-color" content="#ffffff">

    <style>
        /* Khung bao bọc thanh điều hướng */
        .liquid-nav-wrapper {
        position: fixed;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1050;
        border-radius: 40px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.15), 0 0 20px rgba(0,0,0,0.05);
        overflow: hidden;
        width: max-content;
        }

        /* Các lớp cấu thành hiệu ứng Kính lỏng */
        .liquidGlass-effect {
        position: absolute;
        inset: 0;
        backdrop-filter: blur(22px) saturate(180%);
        -webkit-backdrop-filter: blur(22px) saturate(180%);
        filter: url(#glass-distortion);
        background: rgba(255, 255, 255, 0.45);
        }

        .liquidGlass-tint {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.4), rgba(255,255,255,0.05));
        }

        .liquidGlass-shine {
        position: absolute;
        inset: 0;
        box-shadow: inset 2px 2px 6px rgba(255,255,255,0.6), inset -2px -2px 6px rgba(255,255,255,0.2);
        border-radius: 40px;
        }

        /* Container chứa các nút (Dock) */
        .dock {
        display: flex;
        gap: 12px;
        padding: 10px 18px;
        position: relative;
        z-index: 3;
        align-items: center;
        margin: 0;
        }

        /* Nút cơ bản */
        .icon {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        color: #6c757d;
        font-size: 1.4rem;
        text-decoration: none;
        transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
        }

        .icon:hover {
        color: #35a898;
        transform: translateY(-4px);
        }

        /* TRẠNG THÁI ACTIVE GIỐNG ẢNH BẠN YÊU CẦU */
        .icon.active {
        background: linear-gradient(135deg, #6ae3d9, #35a898); /* Dải màu Ngọc bích (Teal/Cyan) */
        color: white !important;
        transform: translateY(-5px); /* Nổi lên trên */
        box-shadow: 0 8px 16px rgba(53, 168, 152, 0.45), 0 0 8px rgba(255, 255, 255, 0.6);
        }

        /* Custom riêng cho nút Center nếu đang Active (để phân biệt màu Role) */
        .icon.center-btn.active.bg-success {
        background: linear-gradient(135deg, #00b14f, #28c76f) !important;
        box-shadow: 0 8px 16px rgba(0, 177, 79, 0.4);
        }

        .icon.center-btn.active.bg-warning {
        background: linear-gradient(135deg, #ffc107, #ff9800) !important;
        box-shadow: 0 8px 16px rgba(255, 193, 7, 0.4);
        }

        .icon.center-btn.active.bg-danger {
        background: linear-gradient(135deg, #dc3545, #f85032) !important;
        box-shadow: 0 8px 16px rgba(220, 53, 69, 0.4);
        }

        /* Hiệu ứng gợn sóng (Ripple) */
        .ripple {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
        transform: translate(-50%, -50%) scale(0);
        background: radial-gradient(circle, rgba(255,255,255,0.8) 0%, transparent 70%);
        mix-blend-mode: overlay;
        animation: rippleAnim 0.6s ease-out forwards;
        }

        @@keyframes rippleAnim {
        to {
        transform: translate(-50%, -50%) scale(4);
        opacity: 0;
        }
        }
    </style>
</head>
<body>

    @if (TempData["Success"] != null || TempData["Error"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function() {
            const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true,
            didOpen: (toast) => {
            toast.addEventListener('mouseenter', Swal.stopTimer)
            toast.addEventListener('mouseleave', Swal.resumeTimer)
            }
            });

            @if (TempData["Success"] != null)
            {
                <text>Toast.fire({ icon: 'success', title: '@Html.Raw(TempData["Success"])' });</text>
            }

            @if (TempData["Error"] != null)
            {
                <text>Toast.fire({ icon: 'error', title: '@Html.Raw(TempData["Error"])' });</text>
            }
            });
        </script>
    }

    <main role="main" class="container-fluid p-3 pb-5 mb-4">
        @RenderBody()
    </main>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="liquid-nav-wrapper">
            <div class="liquidGlass-effect"></div>
            <div class="liquidGlass-tint"></div>
            <div class="liquidGlass-shine"></div>

            <nav class="dock" id="dock">
                @if (User.IsInRole("Customer"))
                {
                    <a asp-controller="Customer" asp-action="Index" class="icon nav-btn" title="Bản đồ">
                        <i class="bi bi-map-fill"></i>
                    </a>
                    <a asp-controller="Customer" asp-action="RideHistory" class="icon nav-btn" title="Lịch sử">
                        <i class="bi bi-clock-history"></i>
                    </a>
                    <a asp-controller="Customer" asp-action="BookRide" class="icon nav-btn center-btn bg-success text-white" title="Đặt xe">
                        <i class="bi bi-car-front-fill"></i>
                    </a>
                    <a asp-controller="Customer" asp-action="Notifications" class="icon nav-btn" title="Thông báo">
                        <i class="bi bi-bell-fill"></i>
                    </a>
                    <a asp-controller="Customer" asp-action="Profile" class="icon nav-btn" title="Hồ sơ">
                        <i class="bi bi-person-fill"></i>
                    </a>
                }
                else if (User.IsInRole("Driver"))
                {
                    <a asp-controller="Driver" asp-action="Wallet" class="icon nav-btn" title="Ví / Doanh thu">
                        <i class="bi bi-wallet-fill"></i>
                    </a>
                    <a asp-controller="Driver" asp-action="RideHistory" class="icon nav-btn" title="Lịch sử chuyến">
                        <i class="bi bi-receipt-cutoff"></i>
                    </a>
                    <a asp-controller="Driver" asp-action="Index" class="icon nav-btn center-btn bg-warning text-white" title="Trạm nhận cuốc">
                        <i class="bi bi-radar"></i>
                    </a>
                    <a asp-controller="Driver" asp-action="Notifications" class="icon nav-btn" title="Thông báo & Nhiệm vụ">
                        <i class="bi bi-bell-fill"></i>
                    </a>
                    <a asp-controller="Driver" asp-action="Profile" class="icon nav-btn" title="Hồ sơ">
                        <i class="bi bi-person-badge-fill"></i>
                    </a>
                }
                else if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="ManageUsers" class="icon nav-btn" title="Người dùng">
                        <i class="bi bi-people-fill"></i>
                    </a>
                    <a asp-controller="Admin" asp-action="Reports" class="icon nav-btn" title="Báo cáo">
                        <i class="bi bi-file-earmark-bar-graph-fill"></i>
                    </a>
                    <a asp-controller="Admin" asp-action="Index" class="icon nav-btn center-btn bg-danger text-white" title="Thống kê">
                        <i class="bi bi-pie-chart-fill"></i>
                    </a>
                    <a asp-controller="Admin" asp-action="Notifications" class="icon nav-btn" title="Thông báo">
                        <i class="bi bi-bell-fill"></i>
                        @if (ViewBag.RevenueWarning != null)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle" style="margin-top: 10px; margin-left: -10px;"></span>
                        }
                    </a>
                    <a asp-controller="Admin" asp-action="Profile" class="icon nav-btn" title="Cài đặt">
                        <i class="bi bi-gear-fill"></i>
                    </a>
                }
            </nav>
        </div>

        <svg style="display:none">
            <filter id="glass-distortion">
                <feTurbulence type="fractalNoise" baseFrequency="0.015" numOctaves="2" />
                <feDisplacementMap in="SourceGraphic" scale="30" />
            </filter>
        </svg>

        <script>
            document.addEventListener('DOMContentLoaded', () => {
            const currentPath = window.location.pathname.toLowerCase();
            const navBtns = document.querySelectorAll('.nav-btn');

            // 1. Phân tích URL để Set Active
            let activeSet = false;

            // Sắp xếp các nút theo độ dài link (href) giảm dần.
            const sortedBtns = Array.from(navBtns).sort((a, b) => b.getAttribute('href').length - a.getAttribute('href').length);

            sortedBtns.forEach(btn => {
            if (activeSet) return;

            let href = btn.getAttribute('href').toLowerCase();
            if (href === '#') return;

            let path = currentPath;

            if (href.endsWith('/') && href.length > 1) href = href.slice(0, -1);
            if (path.endsWith('/') && path.length > 1) path = path.slice(0, -1);

            if (path === href || path === href + '/index' || path + '/index' === href) {
            btn.classList.add('active');
            activeSet = true;
            }
            });

            if (!activeSet && navBtns.length > 0) {
            if (navBtns.length >= 3) {
            navBtns[2].classList.add('active'); // Nút center
            } else {
            navBtns[0].classList.add('active');
            }
            }

            // 2. Xử lý sự kiện Click (Ripple & Active Ảo)
            navBtns.forEach(icon => {
            icon.addEventListener("click", function(e) {
            const ripple = document.createElement("span");
            ripple.className = "ripple";
            const rect = icon.getBoundingClientRect();
            ripple.style.left = (e.clientX - rect.left) + "px";
            ripple.style.top = (e.clientY - rect.top) + "px";
            ripple.style.width = ripple.style.height = "70px";

            icon.appendChild(ripple);
            setTimeout(() => ripple.remove(), 600);

            if(icon.getAttribute('href') === '#') {
            navBtns.forEach(i => i.classList.remove("active"));
            icon.classList.add("active");
            }
            });
            });
            });
        </script>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Driver"))
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
            const currentPath = window.location.pathname.toLowerCase();
            const isMapPage = currentPath === '/driver' || currentPath.includes('/driver/index');

            const isOnline = sessionStorage.getItem('driverOnlineState') === 'true';

            if (!isMapPage && isOnline) {
            fetch('/Driver/ToggleStatus', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ isOnline: true })
            });

            const globalConnection = new signalR.HubConnectionBuilder().withUrl("/rideHub").build();

            globalConnection.on("ReceiveRideRequest", function (rideId, customerName, customerPhone, pickup, dropoff, fare, rideDist, pLat, pLng, declinedJson) {

            const pendingRide = {
            rideId, customerName, customerPhone, pickup, dropoff, fare, rideDist, pLat, pLng, declinedJson,
            timestamp: new Date().getTime()
            };
            sessionStorage.setItem('pendingRideRequest', JSON.stringify(pendingRide));

            if (Notification.permission === "granted") {
            const systemNotification = new Notification("🚕 CÓ CUỐC XE MỚI!", {
            body: `Khách hàng ${customerName} đang đợi. Bấm để mở trạm điều khiển!`,
            icon: 'https://cdn-icons-png.flaticon.com/512/3204/3204066.png',
            vibrate: [200, 100, 200, 100, 200],
            requireInteraction: true
            });
            systemNotification.onclick = function() {
            window.focus();
            window.location.href = '/Driver/Index';
            };
            }

            Swal.fire({
            title: 'CÓ CUỐC XE MỚI!',
            text: `Khách hàng ${customerName} đang đợi bạn.`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#00b14f',
            cancelButtonColor: '#6c757d',
            confirmButtonText: '<i class="bi bi-radar"></i> Về trạm nhận cuốc',
            cancelButtonText: 'Bỏ qua',
            allowOutsideClick: false,
            timer: 15000,
            timerProgressBar: true
            }).then((result) => {
            if (result.isConfirmed) {
            window.location.href = '/Driver/Index';
            } else if (result.dismiss === Swal.DismissReason.cancel) {
            sessionStorage.removeItem('pendingRideRequest');
            }
            });

            const audio = new Audio('/sounds/ringtone.mp3');
            audio.play().catch(e => console.log(e));
            });

            globalConnection.start().catch(err => console.error(err));
            }
            });
        </script>
    }

    @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Customer"))
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
            if ("Notification" in window && Notification.permission !== "granted" && Notification.permission !== "denied") {
            Notification.requestPermission();
            }

            const customerGlobalConnection = new signalR.HubConnectionBuilder().withUrl("/rideHub").build();

            function sendPushNotification(title, body, url) {
            if ("Notification" in window && Notification.permission === "granted") {
            const notif = new Notification(title, {
            body: body,
            icon: 'https://cdn-icons-png.flaticon.com/512/854/854878.png',
            vibrate: [200, 100, 200]
            });
            notif.onclick = function() {
            window.focus();
            if (url) window.location.href = url;
            };
            }
            }

            customerGlobalConnection.on("RideAccepted", function (driverName, driverPhone, driverLat, driverLng, licensePlate, vehicleType) {
            sendPushNotification("Tài xế đang đến!", `Tài xế ${driverName} (${licensePlate}) đang trên đường đón bạn.`, '/Customer/Index');
            });

            customerGlobalConnection.on("DriverArrived", function (dropLat, dropLng) {
            sendPushNotification("Tài xế đã đến nơi!", "Tài xế của bạn đã có mặt tại điểm đón. Vui lòng di chuyển ra xe nhé.", '/Customer/Index');

            let currentPath = window.location.pathname.toLowerCase();
            if (currentPath !== '/customer/index' && currentPath !== '/customer' && currentPath !== '/') {
            Swal.fire({
            title: 'Tài xế đã đến!',
            text: 'Tài xế của bạn đã có mặt tại điểm đón.',
            icon: 'info',
            showCancelButton: true,
            confirmButtonColor: '#00b14f',
            confirmButtonText: 'Xem bản đồ',
            cancelButtonText: 'Đóng'
            }).then((result) => {
            if (result.isConfirmed) window.location.href = '/Customer/Index';
            });
            }
            });

            customerGlobalConnection.on("RideCompleted", function () {
            sendPushNotification("Chuyến đi kết thúc", "Cảm ơn bạn đã sử dụng dịch vụ. Chúc bạn một ngày tốt lành!", '/Customer/RideHistory');
            });

            customerGlobalConnection.start().catch(err => console.error("Global Customer Hub Error: ", err));
            });
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>