@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container-fluid mt-4 px-3 mb-5 pb-5">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Profile" class="text-dark me-3 fs-4"><i class="bi bi-chevron-left"></i></a>
        <h3 class="fw-bold text-dark mb-0">Bảo mật tài khoản</h3>
    </div>

    <div class="glass-panel p-4">
        <div class="text-center mb-4">
            <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                <i class="bi bi-shield-lock-fill fs-2"></i>
            </div>
            <p class="text-muted small">Vui lòng nhập mật khẩu hiện tại và mật khẩu mới để cập nhật bảo mật.</p>
        </div>

        <form asp-action="ChangePassword" method="post">
            <div class="profile-input-group mb-3">
                <i class="bi bi-key"></i>
                <input type="password" name="currentPassword" placeholder="Mật khẩu hiện tại" required />
            </div>

            <hr class="my-4" style="border-top: 1px dashed rgba(0,0,0,0.1);">

            <div class="profile-input-group mb-3">
                <i class="bi bi-lock"></i>
                <input type="password" name="newPassword" placeholder="Mật khẩu mới" required />
            </div>

            <div class="profile-input-group mb-4">
                <i class="bi bi-check-circle"></i>
                <input type="password" name="confirmPassword" placeholder="Xác nhận mật khẩu mới" required />
            </div>

            <button type="submit" class="btn btn-liquid w-100 py-3 rounded-4 shadow-sm fw-bold">
                CẬP NHẬT MẬT KHẨU
            </button>
        </form>
    </div>
</div>