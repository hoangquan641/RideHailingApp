@model IEnumerable<RideHailingApp.DAL.Entities.User>
@{
    ViewData["Title"] = "Quản lý Người dùng";
}

<div class="container mt-4 pb-5 mb-5">
    <h3 class="fw-bold text-dark mb-4"><i class="bi bi-people-fill me-2 text-danger"></i> Quản lý người dùng</h3>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">
            <form asp-action="ManageUsers" method="get" class="row g-2">
                <div class="col-md-4">
                    <select name="roleFilter" class="form-select rounded-pill">
                        <option value="">Tất cả vai trò</option>
                        <option value="Customer" selected="@(ViewBag.RoleFilter == "Customer")">Khách hàng</option>
                        <option value="Driver" selected="@(ViewBag.RoleFilter == "Driver")">Tài xế</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control rounded-pill" placeholder="Tìm theo Tên hoặc Số điện thoại..." />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-danger w-100 rounded-pill"><i class="bi bi-search"></i> Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small">
                    <tr>
                        <th>HỌ TÊN</th>
                        <th>SỐ ĐIỆN THOẠI</th>
                        <th>VAI TRÒ</th>
                        <th>TRẠNG THÁI</th>
                        <th class="text-end">THAO TÁC</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="fw-medium">@user.FullName</td>
                            <td>@user.PhoneNumber</td>
                            <td>
                                @if (user.Role == RideHailingApp.Common.Enums.RoleEnum.Driver)
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-car-front-fill"></i> Tài xế</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-white"><i class="bi bi-person"></i> Khách hàng</span>
                                }
                            </td>
                            <td>
                                @if (user.IsBanned)
                                {
                                    <span class="badge bg-danger">Bị khóa</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                            </td>
                            <td class="text-end">
                                <form asp-action="ToggleUserBan" method="post" class="d-inline">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm @(user.IsBanned ? "btn-success" : "btn-warning") rounded-pill" title="@(user.IsBanned ? "Mở khóa" : "Khóa tài khoản")">
                                        <i class="bi @(user.IsBanned ? "bi-unlock-fill" : "bi-lock-fill")"></i>
                                    </button>
                                </form>

                                <form asp-action="DeleteUser" method="post" class="d-inline ms-1" onsubmit="return confirm('Bạn có chắc chắn muốn XÓA tài khoản này không?');">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger rounded-pill" title="Xóa tài khoản">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Không tìm thấy người dùng nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>