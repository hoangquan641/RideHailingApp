@model List<RideHailingApp.DAL.Entities.Ride>
@{
    ViewData["Title"] = "Báo cáo Doanh thu";
    decimal totalRevenue = ViewBag.TotalRevenue;
}

<div class="container-fluid mt-3 px-3 pb-5 mb-5 no-print">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0">Báo cáo & Thuế</h3>
            <p class="text-muted small">Xuất dữ liệu định kỳ</p>
        </div>
        <div class="d-flex gap-2">
            <button onclick="window.print()" class="btn btn-primary rounded-pill fw-bold shadow-sm px-4">
                <i class="bi bi-printer-fill me-1"></i> Xuất PDF
            </button>
            <a asp-action="ExportExcel" asp-route-fromDate="@ViewBag.FromDate" asp-route-toDate="@ViewBag.ToDate" class="btn btn-success rounded-pill fw-bold shadow-sm px-4">
                <i class="bi bi-file-earmark-excel-fill me-1"></i> Xuất Excel
            </a>
        </div>
    </div>

    <div class="admin-glass-card p-3 mb-4">
        <form asp-action="Reports" method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small text-muted fw-bold">Từ ngày</label>
                <input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control rounded-pill border-0 shadow-sm" />
            </div>
            <div class="col-md-4">
                <label class="form-label small text-muted fw-bold">Đến ngày</label>
                <input type="date" name="toDate" value="@ViewBag.ToDate" class="form-control rounded-pill border-0 shadow-sm" />
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-danger w-100 rounded-pill fw-bold shadow-sm">Lọc dữ liệu</button>
            </div>
        </form>
    </div>
</div>

<div class="print-container px-3">
    <div class="text-center mb-4 pb-3 border-bottom print-header">
        <h2 class="fw-bold text-uppercase">BÁO CÁO DOANH THU & THUẾ</h2>
        <p class="mb-0">Kỳ báo cáo: Từ @ViewBag.FromDate đến @ViewBag.ToDate</p>
        <p class="mb-0">Đơn vị quản lý: Ride Hailing System</p>
    </div>

    <div class="mb-4 d-flex justify-content-between align-items-center">
        <h5 class="fw-bold">Tổng doanh thu kỳ này: <span class="text-danger">@totalRevenue.ToString("N0") VNĐ</span></h5>
        <span class="badge bg-light text-dark border">Tổng số chuyến: @Model.Count()</span>
    </div>

    <div class="table-responsive bg-white rounded-3 shadow-sm p-3">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Mã</th>
                    <th>Hoàn thành lúc</th>
                    <th>Khách hàng</th>
                    <th>Tài xế nhận</th>
                    <th>Quãng đường</th>
                    <th class="text-end">Cước phí</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ride in Model)
                {
                    <tr>
                        <td class="fw-bold text-primary">#@ride.Id</td>
                        <td>@ride.CompletedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@ride.Customer?.FullName</td>
                        <td>@ride.Driver?.FullName</td>
                        <td>@ride.DistanceKm km</td>
                        <td class="text-end fw-bold text-success">@ride.Fare.ToString("N0")đ</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    /* CSS cho bản in PDF: Giấu thanh Nav, nút bấm và hiển thị bảng đen trắng chuẩn A4 */
    @@media print {
        body { background: #fff !important; }
        .no-print, .liquid-nav-wrapper { display: none !important; }
        .print-container { display: block !important; width: 100%; margin: 0; padding: 0; }
        .table, .table * { color: #000 !important; border-color: #dee2e6 !important; }
        .badge { border: 1px solid #000 !important; color: #000 !important; }
        @@page { size: A4 portrait; margin: 1.5cm; }
    }
</style>

<script>
    document.body.classList.add('admin-page');
</script>