@model List<RideHailingApp.DAL.Entities.Ride>
@{
    ViewData["Title"] = "Trung tâm thông báo";
}

<div class="container-fluid mt-4 px-3 mb-5 pb-5">
    <h4 class="fw-bold text-dark mb-4">Thông báo hệ thống</h4>

    @if (ViewBag.RevenueWarning != null)
    {
        <div class="glass-panel p-4 mb-4 border-start border-danger border-5 shadow animate__animated animate__shakeX" style="border-radius: 16px; background: rgba(220, 53, 69, 0.05);">
            <div class="d-flex align-items-center">
                <div class="bg-danger p-3 rounded-circle me-3 shadow-sm">
                    <i class="bi bi-graph-down-arrow text-white fs-3"></i>
                </div>
                <div>
                    <h5 class="fw-bold text-danger mb-1">CẢNH BÁO DOANH THU!</h5>
                    <p class="text-dark mb-0 fw-medium">@ViewBag.RevenueWarning</p>
                </div>
            </div>
        </div>
    }

    <h6 class="fw-bold text-secondary mb-3 mt-2" style="font-size: 0.85rem;">LOG VẬN HÀNH GẦN ĐÂY</h6>

    @foreach (var ride in Model)
    {
        <div class="glass-panel p-3 mb-3 shadow-sm border-0" style="border-radius: 12px; background: white;">
            <div class="d-flex align-items-start">
                <div class="bg-secondary bg-opacity-10 p-2 rounded-circle me-3">
                    <i class="bi bi-exclamation-octagon-fill text-secondary fs-4"></i>
                </div>
                <div class="w-100">
                    <div class="d-flex justify-content-between">
                        <h6 class="fw-bold mb-1 text-dark">Cuốc xe #@ride.Id bị hủy</h6>
                        <small class="text-muted">@ride.CreatedAt.ToString("HH:mm")</small>
                    </div>
                    <p class="text-muted small mb-1">
                        Khách: <b>@ride.Customer?.FullName</b> •
                        Lý do: <span class="text-danger">"@ride.CancelReason"</span>
                    </p>
                    <div class="d-flex justify-content-end">
                        <a asp-action="Index" class="btn btn-sm btn-outline-primary rounded-pill px-3" style="font-size: 0.7rem;">Kiểm tra chi tiết</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>