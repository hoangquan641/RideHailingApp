@{
    ViewData["Title"] = "Thông báo & Nhiệm vụ";
    int currentProgress = ViewBag.QuestProgress;
    int target = 10;
    int percent = (currentProgress * 100) / target;
    if (percent > 100) percent = 100;
}

<div class="container-fluid mt-4 px-3 mb-5 pb-5">
    <h4 class="fw-bold text-dark mb-4">Nhiệm vụ & Cảnh báo</h4>

    @if (ViewBag.CancelRate > 20)
    {
        <div class="alert alert-danger shadow-sm border-0 mb-4" style="border-radius: 16px;">
            <div class="d-flex align-items-center mb-2">
                <i class="bi bi-exclamation-triangle-fill fs-4 me-2"></i>
                <h6 class="fw-bold mb-0">Cảnh báo tỷ lệ hủy chuyến!</h6>
            </div>
            <p class="small mb-1">Tỷ lệ hủy chuyến của bạn đang ở mức <b>@ViewBag.CancelRate%</b> (vượt quá 20%).</p>
            <p class="small mb-0 text-decoration-underline">Vui lòng hạn chế hủy chuyến để tránh bị khóa tài khoản.</p>
        </div>
    }

    <div class="glass-panel p-4 mb-4 shadow-sm" style="border-radius: 20px; border: 2px solid #ffc107;">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="d-flex align-items-center">
                <div class="bg-warning bg-opacity-25 p-2 rounded-circle me-2">
                    <i class="bi bi-trophy-fill text-warning fs-4"></i>
                </div>
                <div>
                    <h6 class="fw-bold mb-0">Thưởng Ngày Năng Động</h6>
                    <small class="text-muted">Hoàn thành @target cuốc xe</small>
                </div>
            </div>
            <span class="badge bg-warning text-dark fs-6">+50.000đ</span>
        </div>

        <div class="d-flex justify-content-between small fw-bold mb-1">
            <span class="text-secondary">Tiến độ</span>
            <span class="text-success">@currentProgress / @target</span>
        </div>
        <div class="progress" style="height: 12px; border-radius: 10px; background-color: #e9ecef;">
            <div class="progress-bar progress-bar-striped progress-bar-animated bg-success"
                 role="progressbar"
                 style="width: @percent%;"
                 aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100"></div>
        </div>

        @if (currentProgress >= target)
        {
            <div class="mt-3 text-center text-success fw-bold">
                <i class="bi bi-check-circle-fill"></i> Đã hoàn thành nhiệm vụ! Tiền thưởng sẽ được cộng vào ví.
            </div>
        }
    </div>

    <h6 class="fw-bold text-secondary mb-3 mt-2" style="font-size: 0.85rem;">TIN TỨC HỆ THỐNG</h6>

    <div class="glass-panel p-3 mb-3 shadow-sm btn-effect" style="border-radius: 12px;">
        <div class="d-flex align-items-start">
            <div class="bg-primary bg-opacity-10 p-2 rounded-circle me-3">
                <i class="bi bi-megaphone-fill text-primary fs-4"></i>
            </div>
            <div>
                <h6 class="fw-bold mb-1 text-dark">Lưu ý khi trời mưa to</h6>
                <p class="text-muted small mb-1">Hệ thống sẽ tự động bật phụ phí thời tiết. Vui lòng lái xe an toàn và giữ khoảng cách.</p>
                <small class="text-secondary" style="font-size: 0.7rem;"><i class="bi bi-clock"></i> 2 giờ trước</small>
            </div>
        </div>
    </div>
</div>