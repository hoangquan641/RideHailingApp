@model IEnumerable<RideHailingApp.DAL.Entities.Ride>
@{
    ViewData["Title"] = "Lịch sử & Thu nhập";
    decimal totalRevenue = ViewBag.TotalRevenue ?? 0;
}

<div class="container mt-3 pb-5 mb-5">
    <div class="card border-0 shadow-sm rounded-4 mb-4 text-white" style="background: linear-gradient(135deg, #00b14f, #28c76f);">
        <div class="card-body text-center py-4">
            <h6 class="fw-medium opacity-75 mb-1"><i class="bi bi-wallet2 me-1"></i> TỔNG DOANH THU TÍCH LŨY</h6>
            <h1 class="fw-bold mb-0 display-4">@totalRevenue.ToString("N0")<span class="fs-4">đ</span></h1>
        </div>
    </div>

    <h5 class="fw-bold text-dark mb-3">Lịch sử nhận cuốc</h5>

    @if (!Model.Any())
    {
        <div class="text-center mt-4">
            <img src="https://cdn-icons-png.flaticon.com/512/7486/7486747.png" width="100" class="opacity-50 mb-3" />
            <h6 class="text-muted">Bạn chưa hoàn thành chuyến xe nào.</h6>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var ride in Model)
            {
                <div class="col-12 col-md-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted small"><i class="bi bi-calendar-event"></i> @ride.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                @if (ride.Status == RideHailingApp.Common.Enums.RideStatusEnum.Completed)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill">Hoàn thành</span>
                                }
                                else if (ride.Status == RideHailingApp.Common.Enums.RideStatusEnum.Cancelled)
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill">Khách hủy</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill">Đang chạy</span>
                                }
                            </div>

                            <div class="d-flex align-items-start mt-3">
                                <div class="d-flex flex-column align-items-center me-3 mt-1">
                                    <i class="bi bi-geo-alt-fill text-primary" style="font-size: 0.8rem;"></i>
                                    <div style="border-left: 2px dashed #dee2e6; height: 20px; margin: 2px 0;"></div>
                                    <i class="bi bi-geo-alt-fill text-danger" style="font-size: 0.8rem;"></i>
                                </div>
                                <div class="w-100">
                                    <div class="mb-2">
                                        <strong class="text-dark small d-block text-truncate" style="max-width: 250px;">@ride.PickupAddress</strong>
                                    </div>
                                    <div>
                                        <strong class="text-dark small d-block text-truncate" style="max-width: 250px;">@ride.DropoffAddress</strong>
                                    </div>
                                </div>
                            </div>

                            <hr class="my-3 border-light">

                            <div class="d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-person-circle fs-4 text-info me-2"></i>
                                    <div>
                                        <small class="text-muted d-block" style="font-size: 0.7rem;">Khách hàng</small>
                                        <span class="fw-medium text-dark small">@(ride.Customer?.FullName ?? "Khách hàng")</span>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <strong class="text-success fs-5">+ @ride.Fare.ToString("N0")đ</strong>
                                    <small class="text-muted d-block" style="font-size: 0.7rem;">@ride.DistanceKm km</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>