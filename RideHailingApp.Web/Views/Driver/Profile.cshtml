@model RideHailingApp.Common.DTOs.UpdateProfileDTO
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    var errorMessage = ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage).FirstOrDefault();
}

<div class="container-fluid mt-4 px-3 mb-5 pb-5">

    <form asp-action="UpdateInfo" method="post" enctype="multipart/form-data">
        <div class="text-center mb-4">
            <div class="position-relative d-inline-block">
                <div class="d-inline-flex justify-content-center align-items-center bg-white rounded-circle shadow-sm"
                     style="width: 110px; height: 110px; border: 4px solid #f4f6f9; overflow: hidden;">

                    @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                    {
                        <img src="@Model.AvatarUrl" id="avatarPreview" style="width: 100%; height: 100%; object-fit: cover;" />
                    }
                    else
                    {
                        <i class="bi bi-person-fill text-secondary" id="avatarIcon" style="font-size: 4.5rem;"></i>
                        <img id="avatarPreview" style="width: 100%; height: 100%; object-fit: cover; display: none;" />
                    }
                </div>

                <label for="fileInput" class="position-absolute bottom-0 end-0 bg-success text-white rounded-circle d-flex align-items-center justify-content-center shadow"
                       style="width: 32px; height: 32px; cursor: pointer; border: 2px solid white;">
                    <i class="bi bi-camera-fill" style="font-size: 0.9rem;"></i>
                </label>
                <input type="file" name="avatarFile" id="fileInput" class="d-none" accept="image/*" onchange="previewImage(this)" />
            </div>

            <h3 class="fw-bold text-dark mt-2 mb-1">@Model.FullName</h3>
            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 border border-success border-opacity-25">
                <i class="bi bi-patch-check-fill me-1"></i> @ViewBag.RoleName
            </span>
        </div>

        <div class="glass-panel p-4 mb-4">
            <h6 class="text-muted mb-3 fw-bold"><i class="bi bi-info-circle-fill me-2"></i>THÔNG TIN CÁ NHÂN</h6>

            <div class="profile-input-group mb-3">
                <i class="bi bi-person-vcard"></i>
                <input asp-for="FullName" placeholder="Nhập họ và tên..." required />
            </div>

            <div class="profile-input-group mb-3">
                <i class="bi bi-envelope"></i>
                <input asp-for="Email" type="email" placeholder="Nhập địa chỉ Email..." required />
            </div>

            <div class="profile-input-group mb-4" style="background-color: #e9ecef; opacity: 0.8;">
                <i class="bi bi-telephone text-secondary"></i>
                <input asp-for="PhoneNumber" placeholder="Số điện thoại liên lạc..." readonly class="text-secondary fw-bold" style="cursor: not-allowed;" />
            </div>

            <h6 class="text-muted mb-3 fw-bold mt-4"><i class="bi bi-car-front-fill me-2"></i>THÔNG TIN PHƯƠNG TIỆN</h6>

            <div class="profile-input-group mb-3">
                <i class="bi bi-tag-fill"></i>
                <select asp-for="VehicleType" class="form-control border-0 shadow-none bg-transparent" style="outline: none;">
                    <option value="">-- Chọn loại xe --</option>
                    <option value="Xe máy (Bike)">Xe máy (Bike)</option>
                    <option value="Ô tô 4 chỗ (Car)">Ô tô 4 chỗ (Car)</option>
                </select>
            </div>

            <div class="profile-input-group mb-4">
                <i class="bi bi-123"></i>
                <input asp-for="LicensePlate" placeholder="Nhập biển số xe (VD: 59-X1 123.45)..." />
            </div>

            <button type="submit" class="btn btn-liquid w-100 py-3 rounded-4 shadow-sm fs-6 fw-bold">
                LƯU THAY ĐỔI
            </button>

            <div class="text-center mt-3">
                <a asp-action="ChangePassword" class="btn btn-outline-secondary w-100 py-2 rounded-4 shadow-sm fs-6">
                    <i class="bi bi-shield-lock me-1"></i> ĐỔI MẬT KHẨU
                </a>
            </div>
        </div>
    </form>

    <a asp-controller="Auth" asp-action="Logout" class="btn btn-white w-100 py-3 rounded-4 fw-bold shadow-sm" style="color: #dc3545; border: 1px solid rgba(220,53,69,0.2); background: white;">
        <i class="bi bi-box-arrow-right me-2"></i> ĐĂNG XUẤT TÀI KHOẢN
    </a>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Hiển thị lỗi Validation nếu có
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <text>
                Swal.fire({
                toast: true, position: 'top-end',
                icon: 'error', title: '@Html.Raw(errorMessage)',
                showConfirmButton: false, timer: 3500
                });
            </text>
        }

        // JS Xử lý hiển thị ảnh Preview
        function previewImage(input) {
        if (input.files && input.files[0]) {
        var reader = new FileReader();
        reader.onload = function(e) {
        document.getElementById('avatarPreview').src = e.target.result;
        document.getElementById('avatarPreview').style.display = 'block';
        if(document.getElementById('avatarIcon'))
        document.getElementById('avatarIcon').style.display = 'none';
        }
        reader.readAsDataURL(input.files[0]);
        }
        }
    </script>
}